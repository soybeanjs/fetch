{
  "name": "@soybeanjs/fetch",
  "version": "0.0.1",
  "description": "A lightweight, type-safe HTTP request library based on native fetch",
  "homepage": "https://github.com/soybeanjs/fetch",
  "bugs": {
    "url": "https://github.com/soybeanjs/fetch/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean",
    "email": "soybeanjs@outlook.com",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "url": "https://github.com/soybeanjs/fetch.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "commit": "soy git-commit",
    "commit:zh": "soy git-commit -l=zh-cn",
    "fmt": "vp fmt",
    "lint": "vp lint --fix",
    "publish-pkg": "pnpm -r publish --access public",
    "release": "soy release",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "upkg": "soy ncu"
  },
  "devDependencies": {
    "@soybeanjs/cli": "^1.7.2",
    "@soybeanjs/oxc-config": "^0.2.3",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.15.1"
}
